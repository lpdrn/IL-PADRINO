# Copy to .env.local for local dev. On Vercel, set these under
# Project → Settings → Environment Variables instead (this file is never
# read there — Vercel doesn't upload .env.local).

# Meta Pixel ID — activates components/MetaPixel.tsx (client-side PageView +
# CompleteRegistration on CTA click). Find it in Meta Events Manager →
# Data Sources → Pixels.
NEXT_PUBLIC_META_PIXEL_ID=

# TikTok Pixel ID — activates components/TikTokPixel.tsx (client-side page
# view + CompleteRegistration on CTA click). Find it in TikTok Ads Manager →
# Tools → Events → Web Events → your pixel.
NEXT_PUBLIC_TIKTOK_PIXEL_ID=

# TikTok Events API access token — lets app/api/capi/route.ts forward the
# real registration/deposit postback to TikTok (server-side), the TikTok
# equivalent of META_CAPI_ACCESS_TOKEN. Generate in TikTok Events Manager →
# your pixel → Settings → Events API → Generate access token.
TIKTOK_EVENTS_API_TOKEN=

# Meta Conversions API access token — powers app/api/capi/route.ts (the
# server-side webhook your affiliate network's postback calls). Generate in
# Meta Events Manager → your pixel → Settings → Conversions API → Generate
# access token.
META_CAPI_ACCESS_TOKEN=

# A secret string you invent yourself (e.g. a random 32-char string). Put the
# same value in the affiliate network's postback URL as `&secret=...` so
# random callers can't inject fake events into your pixel.
CAPI_WEBHOOK_SECRET=

# --- Telegram join-notification bot (app/api/telegram-webhook/route.ts) ---
# Sends YOU a Telegram message whenever someone joins the channel, naming
# which campaign invite link (if any) they used. See README for full setup.

# Bot token from @BotFather (create a bot, add it as ADMIN of the channel).
TELEGRAM_BOT_TOKEN=

# A secret string you invent yourself; passed to Telegram's setWebhook as
# secret_token so random callers can't fake join notifications.
TELEGRAM_WEBHOOK_SECRET=

# The chat id that should receive notifications (usually your own DM with
# the bot). Message the bot once, then check
# https://api.telegram.org/bot<TOKEN>/getUpdates for "chat":{"id": ...}.
TELEGRAM_NOTIFY_CHAT_ID=
